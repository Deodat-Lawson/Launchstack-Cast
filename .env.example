# Database
DATABASE_URL=postgres://cast:cast@localhost:5432/cast?sslmode=disable

# Data directory for video files and keyframes
CAST_DATA_DIR=./data

# Python
CAST_PYTHON_BIN=python3
CAST_PYTHON_ROOT=./python

# LLM
ANTHROPIC_API_KEY=

# Server
CAST_ADDR=:8080
CAST_ENV=dev

# Worker
CAST_WORKER_CONCURRENCY=2
CAST_WORKER_POLL_INTERVAL=2s

# Python worker timeouts (seconds)
CAST_PY_TIMEOUT_TRANSCRIBE=300
CAST_PY_TIMEOUT_VISUAL_EMBED=120
CAST_PY_TIMEOUT_FACES=120
